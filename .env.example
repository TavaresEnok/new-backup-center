# Copie para .env e preencha. Nunca commite .env.
#
# Obrigatório em produção (ver app/core/config.py — validate_settings)
APP_ENV=development
DEBUG=0
SECRET_KEY=generate-with-secrets-token-hex-or-openssl
ENCRYPTION_KEY=generate-with-python-cryptography-fernet

# Base de dados (Compose usa DB_PASSWORD e DB_PASSWORD_URLENC para URL)
DATABASE_URL=postgresql://backup_user:CHANGE_ME@127.0.0.1:5432/backup_center
DB_PASSWORD=CHANGE_ME
DB_PASSWORD_URLENC=CHANGE_ME

REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379/0
REDIS_PASSWORD=CHANGE_ME
REDIS_APPENDONLY=no
REDIS_SAVE_SEC_1=3600
REDIS_SAVE_CHG_1=1
REDIS_SAVE_SEC_2=300
REDIS_SAVE_CHG_2=100000
REDIS_SAVE_SEC_3=60
REDIS_SAVE_CHG_3=1000000
REDIS_MAXMEMORY=0
REDIS_MAXMEMORY_POLICY=noeviction
REDIS_TCP_BACKLOG=511
REDIS_CLIENT_TIMEOUT_SECONDS=0
REDIS_HZ=10
REDIS_ACTIVE_EXPIRE_EFFORT=1

APP_TIMEZONE=America/Recife

# Runtime web
APP_WEB_WORKERS=6
APP_WEB_MAX_REQUESTS=1500
APP_WEB_MAX_REQUESTS_JITTER=150
APP_WEB_TIMEOUT_SECONDS=120
APP_WEB_GRACEFUL_TIMEOUT_SECONDS=30
APP_WEB_KEEPALIVE_SECONDS=10
BULK_STATUS_REFRESH_MIN_INTERVAL_SECONDS=5
APP_CELERY_METRICS_INSPECT_ENABLED=0
BACKUP_METRICS_CACHE_SECONDS=60
REALTIME_TASK_LOG_MAX_ENTRIES=2000
REALTIME_GLOBAL_LOG_MAX_ENTRIES=50000
REALTIME_GLOBAL_PRUNE_INTERVAL_SECONDS=300

# Celery/IO: valores conservadores para evitar saturar disco/Redis durante lotes.
CELERY_WORKER_CONCURRENCY=4
CELERY_JUMP_WORKER_CONCURRENCY=16
CELERY_VPN_WORKER_CONCURRENCY=1
CELERY_BEAT_SCHEDULED_BACKUPS_SECONDS=300

# SSH de equipamentos: 0 preserva compatibilidade com legados/host keys ausentes.
# Use 1 apenas quando known_hosts estiver gerenciado nos containers.
BACKUP_SSH_STRICT_HOST_KEY_CHECKING=0

# PostgreSQL tuning
PG_MAX_CONNECTIONS=250
PG_SHARED_BUFFERS=512MB
PG_EFFECTIVE_CACHE_SIZE=2048MB
PG_WORK_MEM=8MB
PG_MAINTENANCE_WORK_MEM=128MB
PG_MAX_WAL_SIZE=1GB
PG_MIN_WAL_SIZE=80MB
# Opcional: billing Mercado Pago
# MERCADO_PAGO_ACCESS_TOKEN=
# MERCADO_PAGO_PUBLIC_KEY=
# MERCADO_PAGO_WEBHOOK_TOKEN=

# Precheck direto/VPN continua ativo; via Jump Host ele gera conexao extra no bastiao.
BACKUP_NETWORK_PRECHECK_SKIP_FOR_JUMP=1

# Jump hosts: mapa de slots por host (formato interno). Ex.: default=1,IP:porta=N,...
# Deixe vazio para usar só default interno; em produção defina no .env real, não no Git.
JUMP_HOST_MAX_SLOTS=3
JUMP_HOST_SLOTS_OVERRIDES=default=1
JUMP_HOST_SLOT_WAIT_SECONDS_LARGE_BULK=900
JUMP_HOST_SLOT_TTL_SECONDS=660
VPN_CONNECT_RETRIES=4
VPN_CONNECT_RETRY_BACKOFF_SECONDS=10
VPN_RESET_BACKEND_ON_CONNECT_FAILURE=1
VPN_RESTART_NETWORKMANAGER_ON_CONNECT_FAILURE=1
VPN_RECYCLE_WORKER_AFTER_CONNECT_FAILURE=0
VPN_WORKER_RECYCLE_DELAY_SECONDS=10

# Flower (monitor Celery): use password forte em produção.
# Browser: Basic Auth. Desative exposição pública ou use VPN/firewall.
FLOWER_BASIC_AUTH=flower_user:CHANGE_THIS_STRONG_PASSWORD
# FLOWER_UNAUTHENTICATED_API deve permanecer false (padrão seguro) — ver docker-compose.yml
